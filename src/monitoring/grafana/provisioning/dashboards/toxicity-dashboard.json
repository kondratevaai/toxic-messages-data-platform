{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Last N Predictions (s3-csv source)",
      "description": "Recent toxicity predictions from the s3-csv data source. Scalable: duplicate this panel and change the URL filter for each new source (e.g. reddit).",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://backend-api:8000/monitoring/recent?limit=50",
          "url_options": { "method": "GET" },
          "root_selector": "",
          "columns": [
            { "selector": "id", "text": "ID", "type": "number" },
            { "selector": "timestamp", "text": "Timestamp", "type": "timestamp" },
            { "selector": "source", "text": "Source", "type": "string" },
            { "selector": "text_raw", "text": "Text", "type": "string" },
            { "selector": "prediction_label", "text": "Prediction", "type": "string" },
            { "selector": "processing_time_ms", "text": "Processing Time (ms)", "type": "number" },
            { "selector": "text_length", "text": "Text Length", "type": "number" }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Text" },
            "properties": [
              { "id": "custom.width", "value": 500 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Prediction" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "toxic": { "text": "TOXIC", "color": "red" }, "non_toxic": { "text": "OK", "color": "green" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Processing Time (ms)" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "decimals", "value": 1 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Timestamp", "desc": true }]
      },
      "transformations": []
    },
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(http_requests_total{handler=\"/forward\"}[1m])",
          "legendFormat": "/forward req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list" }
      }
    },
    {
      "title": "Processing Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{handler=\"/forward\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler=\"/forward\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{handler=\"/forward\"}[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list" }
      }
    },
    {
      "title": "Total Predictions",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 18 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "http_requests_total{handler=\"/forward\", method=\"POST\"}",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "value": null, "color": "blue" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Avg Processing Time",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 18 },
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(http_request_duration_seconds_sum{handler=\"/forward\"}[5m]) / rate(http_request_duration_seconds_count{handler=\"/forward\"}[5m])",
          "legendFormat": "avg latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.5, "color": "yellow" },
              { "value": 1, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "title": "HTTP Status Codes (/forward)",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 18 },
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(http_requests_total{handler=\"/forward\"}[1h])",
          "legendFormat": "{{status}} {{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      }
    },
    {
      "title": "Request Duration Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 18 },
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(http_request_duration_seconds_bucket{handler=\"/forward\"}[5m])",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "color": { "scheme": "Oranges" },
        "yAxis": { "unit": "s" }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["toxicity", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Toxicity Detection Platform",
  "uid": "toxicity-platform",
  "version": 1
}
