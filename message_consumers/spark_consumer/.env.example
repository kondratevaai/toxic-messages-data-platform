# Kafka Configuration
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPICS=toxic-messages

# FastAPI Service Configuration
API_URL=http://backend-api:8000
# API_TOKEN=your_jwt_token_here  # Uncomment and set if API requires authentication

# Spark Processing Configuration
BATCH_TIMEOUT_MS=10000         # Process messages every 10 seconds
CHECKPOINT_DIR=/tmp/spark_consumer_checkpoint

# Retry Configuration
MAX_RETRIES=3                  # Number of retries for failed API calls
REQUEST_TIMEOUT_S=30           # Request timeout in seconds

# Logging
LOG_LEVEL=INFO
